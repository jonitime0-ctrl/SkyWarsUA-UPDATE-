rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: verificationRequests
    // Document ID: {requestId}
    // Fields:
    //   - userId: string (required)
    //   - gmail: string (required)
    //   - tgChannel: string (required)
    //   - videoLink: string (required)
    //   - createdAt: timestamp (required)
    //   - status: string (required) - 'pending', 'approved', 'rejected'
    //
    // Collection: dashboard
    // Document ID: status
    // Fields:
    //   - markedAirfields: list of strings (required) - Active airfield IDs
    //   - ballisticDir: string (required) - Current ballistic threat direction
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - email: string (required)
    //   - displayName: string (required)
    //   - createdAt: timestamp (required)
    //   - isVerified: boolean (required)
    //   - role: string (required) - User role ('admin', 'moder', 'helper', 'user', 'fake', 'scam', 'ban')
    //   - isSponsor: boolean (optional)
    //
    // Collection: topics
    // Document ID: {topicId}
    // Fields:
    //   - title: string (required)
    //   - authorId: string (required)
    //   - createdAt: timestamp (required)
    //   - messageCount: number (required)
    //   - pinned: boolean (optional)
    //
    // Collection: messages
    // Document ID: {messageId}
    // Fields:
    //   - text: string (required)
    //   - authorId: string (required)
    //   - createdAt: timestamp (required)
    //   - topicId: string (required)
    //   - isVoice: boolean (required)
    //   - audioData: string (optional)
    //   - likes: list (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email in ["olegkucher2311@gmail.com", "vnozab@gmail.com", "jdmsamurai324@gmail.com"]) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isModer() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'moder';
    }

    function canManageThreats() {
      return isAdmin() || isModer();
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidDashboardStatus(data) {
      return (!('markedAirfields' in data) || (data.markedAirfields is list && data.markedAirfields.size() <= 100)) &&
             (!('ballisticDirs' in data) || (data.ballisticDirs is list && data.ballisticDirs.size() <= 10)) &&
             (!('shahedThreats' in data) || (data.shahedThreats is list && data.shahedThreats.size() <= 100)) &&
             (!('activeStrategicAirfields' in data) || (data.activeStrategicAirfields is list && data.activeStrategicAirfields.size() <= 100)) &&
             (!('ballisticDir' in data) || data.ballisticDir == null || data.ballisticDir is string) &&
             (!('radioStatus' in data) || data.radioStatus == null || data.radioStatus in ['НЕ АКТИВНІ', 'МІНІМАЛЬНА', 'АКТИВНІ']) &&
             (!('fleetStatus' in data) || data.fleetStatus == null || data.fleetStatus in ['В МОРІ НЕ ПЕРЕБУВАЄ', 'В МОРІ ПЕРЕБУВАЄ']) &&
             (!('strategicStatus' in data) || data.strategicStatus == null || data.strategicStatus in ['НЕ АКТИВНА', 'МІНІМАЛЬНА', 'АКТИВНА']) &&
             (!('tacticalStatus' in data) || data.tacticalStatus == null || data.tacticalStatus in ['НЕ АКТИВНА', 'МІНІМАЛЬНА', 'АКТИВНА']);
    }

    function isValidUser(data) {
      return hasOnlyAllowedFields(['email', 'displayName', 'createdAt', 'isVerified', 'role', 'photoURL', 'description', 'isSponsor', 'chevronUrl', 'followers', 'following', 'blockedSections', 'bannerUrl', 'bannerColor', 'allowMessages', 'isFrozen', 'freezeReason', 'frozenFeatures', 'isPermanentlyBlocked', 'fakeFollowersCount', 'fakeFollowingCount', 'firstName', 'lastName', 'phone', 'registrationMethod']) &&
             hasRequiredFields(['email', 'displayName', 'createdAt', 'isVerified', 'role']) &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 50 &&
             data.createdAt is timestamp &&
             data.isVerified is bool &&
             data.role in ['admin', 'moder', 'helper', 'user', 'fake', 'scam', 'ban'] &&
             (!('photoURL' in data) || data.photoURL == null || (data.photoURL is string && data.photoURL.size() < 1048576)) &&
             (!('bannerUrl' in data) || data.bannerUrl == null || (data.bannerUrl is string && data.bannerUrl.size() < 1048576)) &&
             (!('bannerColor' in data) || data.bannerColor == null || (data.bannerColor is string && data.bannerColor.size() < 50)) &&
             (!('description' in data) || data.description == null || (data.description is string && data.description.size() <= 500)) &&
             (!('isSponsor' in data) || data.isSponsor is bool) &&
             (!('chevronUrl' in data) || data.chevronUrl == null || (data.chevronUrl is string && data.chevronUrl.size() < 1048576)) &&
             (!('followers' in data) || data.followers is list) &&
             (!('following' in data) || data.following is list) &&
             (!('fakeFollowersCount' in data) || data.fakeFollowersCount == null || data.fakeFollowersCount is number) &&
             (!('fakeFollowingCount' in data) || data.fakeFollowingCount == null || data.fakeFollowingCount is number) &&
             (!('blockedSections' in data) || data.blockedSections is list) &&
             (!('frozenFeatures' in data) || data.frozenFeatures is list) &&
             (!('isFrozen' in data) || data.isFrozen is bool) &&
             (!('isPermanentlyBlocked' in data) || data.isPermanentlyBlocked is bool) &&
             (!('freezeReason' in data) || data.freezeReason == null || (data.freezeReason is string && data.freezeReason.size() <= 1000)) &&
             (!('allowMessages' in data) || data.allowMessages is bool) &&
             (!('firstName' in data) || data.firstName is string) &&
             (!('lastName' in data) || data.lastName is string) &&
             (!('phone' in data) || data.phone is string) &&
             (!('registrationMethod' in data) || data.registrationMethod is string);
    }

    function isValidTopic(data) {
      return hasOnlyAllowedFields(['title', 'authorId', 'createdAt', 'messageCount', 'pinned', 'reactions', 'image', 'poll', 'coAuthors', 'collaborationEmail', 'status', 'pendingCoAuthors', 'isEdited']) &&
             hasRequiredFields(['title', 'authorId', 'createdAt', 'messageCount']) &&
             data.title is string && data.title.size() < 1000 &&
             data.authorId is string && data.authorId.size() < 100 &&
             data.createdAt is timestamp &&
             data.messageCount is number && data.messageCount >= 0 &&
             (!('pinned' in data) || data.pinned is bool) &&
             (!('reactions' in data) || data.reactions is map) &&
             (!('image' in data) || data.image is string) &&
             (!('poll' in data) || data.poll is map) &&
             (!('coAuthors' in data) || data.coAuthors is list) &&
             (!('collaborationEmail' in data) || data.collaborationEmail is string) &&
             (!('status' in data) || data.status in ['published', 'pending_coauthors', 'cancelled']) &&
             (!('pendingCoAuthors' in data) || data.pendingCoAuthors is list) &&
             (!('isEdited' in data) || data.isEdited is bool);
    }

    function isValidMessage(data) {
      return hasOnlyAllowedFields(['text', 'authorId', 'createdAt', 'topicId', 'isVoice', 'audioData', 'replyTo', 'likes', 'reactions']) &&
             hasRequiredFields(['text', 'authorId', 'createdAt', 'topicId', 'isVoice']) &&
             data.text is string && data.text.size() < 5000 &&
             data.authorId is string && data.authorId.size() < 100 &&
             data.createdAt is timestamp &&
             data.topicId is string && data.topicId.size() < 100 &&
             data.isVoice is bool &&
             (!('audioData' in data) || (data.audioData is string && data.audioData.size() < 1048576)) &&
             (!('replyTo' in data) || (data.replyTo is string && data.replyTo.size() < 100)) &&
             (!('likes' in data) || data.likes is list) &&
             (!('reactions' in data) || data.reactions is map);
    }

    function isValidChannel(data) {
      return hasOnlyAllowedFields(['name', 'description', 'type', 'avatarUrl', 'adminId', 'members', 'bannedUsers', 'writeAccess', 'passcode', 'createdAt']) &&
             hasRequiredFields(['name', 'adminId', 'members', 'writeAccess', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (!('description' in data) || data.description == null || data.description is string) &&
             (!('type' in data) || data.type == null || data.type is string) &&
             (!('avatarUrl' in data) || data.avatarUrl == null || data.avatarUrl is string) &&
             data.adminId is string && data.adminId.size() > 0 &&
             data.members is list && data.members.size() <= 1000 &&
             (!('bannedUsers' in data) || data.bannedUsers is list && data.bannedUsers.size() <= 1000) &&
             data.writeAccess in ['admin_only', 'all_members'] &&
             (!('passcode' in data) || data.passcode == null || (data.passcode is string && data.passcode.size() <= 10)) &&
             data.createdAt is timestamp;
    }

    function isValidChannelMessage(data) {
      return hasOnlyAllowedFields(['text', 'authorId', 'authorName', 'authorAvatar', 'createdAt', 'image', 'poll', 'isVoice', 'audioData', 'reactions', 'commentsCount']) &&
             hasRequiredFields(['authorId', 'authorName', 'createdAt']) &&
             (!('text' in data) || (data.text is string && data.text.size() <= 2000)) &&
             data.authorId is string && data.authorId.size() > 0 &&
             data.authorName is string && data.authorName.size() > 0 &&
             (!('authorAvatar' in data) || data.authorAvatar == null || data.authorAvatar is string) &&
             (!('image' in data) || data.image == null || data.image is string) &&
             (!('poll' in data) || data.poll is map) &&
             (!('isVoice' in data) || data.isVoice is bool) &&
             (!('audioData' in data) || data.audioData == null || data.audioData is string) &&
             (!('reactions' in data) || data.reactions is map) &&
             (!('commentsCount' in data) || data.commentsCount is number) &&
             data.createdAt is timestamp;
    }

    function isValidStoreItem(data) {
      return hasOnlyAllowedFields(['title', 'description', 'price', 'contactLink', 'image', 'createdAt']) &&
             hasRequiredFields(['title', 'description', 'price', 'contactLink', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.description is string && data.description.size() <= 1000 &&
             data.price is string && data.price.size() <= 50 &&
             data.contactLink is string && data.contactLink.size() <= 500 &&
             (!('image' in data) || data.image == null || data.image is string) &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /storeItems/{itemId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidStoreItem(request.resource.data);
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /systemSettings/{docId} {
      allow read: if true;
      allow write: if isAdmin() || (isAuthenticated() && request.auth.token.email == "olegkucher2311@gmail.com");
    }

    match /verificationRequests/{requestId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && 
                    request.resource.data.keys().hasAll(['userId', 'gmail', 'tgChannel', 'videoLink', 'createdAt', 'status']) &&
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.status == 'pending';
      allow update: if isAdmin() && 
                    request.resource.data.status in ['approved', 'rejected'];
      allow delete: if false;
    }

    match /threats/{threatId} {
      allow read: if true;
      allow create: if canManageThreats() && 
                    request.resource.data.keys().hasAll(['type', 'message', 'timestamp']) &&
                    request.resource.data.type in ['ballistic', 'airfield', 'system', 'info'] &&
                    request.resource.data.message is string &&
                    request.resource.data.message.size() < 200 &&
                    (!('authorEmail' in request.resource.data) || (request.resource.data.authorEmail is string && request.resource.data.authorEmail.size() < 100));
      allow delete: if canManageThreats();
      allow update: if false;
    }

    match /presence/{docId} {
      allow read: if true;
      allow create, update: if 
        (request.resource.data.keys().hasAll(['lastActive', 'role']) &&
         request.resource.data.role in ['admin', 'viewer', 'user'] &&
         (!('userAgent' in request.resource.data) || (request.resource.data.userAgent is string && request.resource.data.userAgent.size() < 300))) 
        ||
        (request.resource.data.keys().hasAll(['state', 'lastChanged']) &&
         request.resource.data.state in ['online', 'offline'] &&
         request.resource.data.lastChanged is timestamp);
      allow delete: if isOwner(docId) || isAdmin() || true; // allow delete for sessionIds
    }

    match /situationUpdates/{updateId} {
      allow read: if true;
      allow create: if canManageThreats();
      allow delete: if canManageThreats();
      allow update: if false;
    }

    match /dashboard/status {
      // Anyone can read the current status
      allow read: if true;
      // Only admins and moders can update or create the status
      allow create: if canManageThreats() && isValidDashboardStatus(request.resource.data);
      allow update: if canManageThreats() && isValidDashboardStatus(request.resource.data);
      allow delete: if false; // Status should not be deleted
    }

    match /support_chat/{messageId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['text', 'senderId', 'room', 'isAdmin', 'timestamp']) &&
                       request.resource.data.text is string &&
                       request.resource.data.text.size() > 0 &&
                       request.resource.data.text.size() < 1000 &&
                       request.resource.data.senderId is string &&
                       request.resource.data.senderId.size() < 100 &&
                       request.resource.data.room is string &&
                       request.resource.data.room.size() < 100 &&
                       request.resource.data.isAdmin is bool;
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /ai_usage/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/notifications/{notificationId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(userId) || isAdmin();
    }

    match /users/{userId} {
      // Users can read their own profile, admins can read all, wait, everyone needs to see profiles for chat
      allow read: if isAuthenticated();
      
      // Users can create their own profile. Default role is 'user', isVerified is false, chevronUrl is omitted.
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) &&
                    request.resource.data.role == 'user' && 
                    request.resource.data.isVerified == false &&
                    !('chevronUrl' in request.resource.data) &&
                    !('fakeFollowersCount' in request.resource.data) &&
                    !('fakeFollowingCount' in request.resource.data);
                    
      // Users can update their own profile (except role, isVerified, isSponsor, chevronUrl, followers). Admins can update any profile.
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (
                      (isOwner(userId) && 
                       request.resource.data.role == resource.data.role && 
                       request.resource.data.isVerified == resource.data.isVerified &&
                       request.resource.data.isSponsor == resource.data.isSponsor &&
                       (!('chevronUrl' in request.resource.data) || request.resource.data.chevronUrl == resource.data.chevronUrl) &&
                       (!('fakeFollowersCount' in request.resource.data) || request.resource.data.fakeFollowersCount == resource.data.fakeFollowersCount) &&
                       (!('fakeFollowingCount' in request.resource.data) || request.resource.data.fakeFollowingCount == resource.data.fakeFollowingCount) &&
                       (!('followers' in request.resource.data) || request.resource.data.followers == resource.data.followers)) || 
                      isAdmin() ||
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers']))
                    );
      allow delete: if false;
    }

    match /topics/{topicId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidTopic(request.resource.data) && 
                    request.resource.data.authorId == request.auth.uid &&
                    request.resource.data.messageCount == 0 &&
                    (!('coAuthors' in request.resource.data) || request.resource.data.coAuthors is list) &&
                    (!('pendingCoAuthors' in request.resource.data) || request.resource.data.pendingCoAuthors is list) &&
                    (!('status' in request.resource.data) || request.resource.data.status in ['published', 'pending_coauthors', 'cancelled']) &&
                    (!('collaborationEmail' in request.resource.data) || request.resource.data.collaborationEmail is string);
      // Allow anyone to increment messageCount, but only by 1. Allow anyone to update reactions. Admins can update anything (like pinned).
      allow update: if (isAuthenticated() && isValidTopic(request.resource.data) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['messageCount', 'reactions', 'poll']) &&
                    (
                      (!('messageCount' in request.resource.data.diff(resource.data).affectedKeys()) || 
                       request.resource.data.messageCount == resource.data.messageCount + 1 || 
                       request.resource.data.messageCount == resource.data.messageCount - 1)
                    )) ||
                    (isAdmin() && isValidTopic(request.resource.data)) ||
                    (isAuthenticated() && isValidTopic(request.resource.data) && isOwner(resource.data.authorId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'image', 'poll', 'isEdited'])) ||
                    (isAuthenticated() && isValidTopic(request.resource.data) && ('pendingCoAuthors' in resource.data) && (request.auth.uid in resource.data.pendingCoAuthors) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'coAuthors', 'pendingCoAuthors']));
      allow delete: if isAdmin() || isOwner(resource.data.authorId);
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMessage(request.resource.data) &&
                    request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthenticated() && isValidMessage(request.resource.data) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasAny(['likes', 'reactions']) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'reactions']);
      allow delete: if isAdmin() || isOwner(resource.data.authorId);
    }

    match /channels/{channelId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidChannel(request.resource.data) &&
                    request.resource.data.adminId == request.auth.uid;
      allow update: if isAuthenticated() && isValidChannel(request.resource.data) &&
                    (
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) &&
                       request.resource.data.members.hasAll(resource.data.members) &&
                       request.resource.data.members.size() == resource.data.members.size() + 1 &&
                       request.auth.uid in request.resource.data.members) ||
                      (isAdmin() || isOwner(resource.data.adminId))
                    );
      allow delete: if isAdmin() || isOwner(resource.data.adminId);

      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidChannelMessage(request.resource.data) &&
                      request.resource.data.authorId == request.auth.uid &&
                      (
                        get(/databases/$(database)/documents/channels/$(channelId)).data.writeAccess == 'all_members' ||
                        get(/databases/$(database)/documents/channels/$(channelId)).data.adminId == request.auth.uid
                      );
        allow update: if isAuthenticated() && isValidChannelMessage(request.resource.data) &&
                      (
                        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['poll']) &&
                         request.resource.data.poll.keys().hasAll(['options', 'votes']) &&
                         request.resource.data.poll.options == resource.data.poll.options) ||
                        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])) ||
                        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentsCount']) &&
                         (request.resource.data.commentsCount == resource.data.commentsCount + 1 || request.resource.data.commentsCount == resource.data.commentsCount - 1))
                      );
        allow delete: if isAdmin() || isOwner(resource.data.authorId) || get(/databases/$(database)/documents/channels/$(channelId)).data.adminId == request.auth.uid;

        match /comments/{commentId} {
          allow read: if isAuthenticated();
          allow create: if isAuthenticated() &&
                        request.resource.data.keys().hasAll(['text', 'authorId', 'authorName', 'createdAt']) &&
                        request.resource.data.text is string && request.resource.data.text.size() <= 1000 &&
                        request.resource.data.authorId == request.auth.uid &&
                        request.resource.data.authorName is string &&
                        request.resource.data.createdAt is timestamp;
          allow update: if false;
          allow delete: if isAdmin() || isOwner(resource.data.authorId) || get(/databases/$(database)/documents/channels/$(channelId)).data.adminId == request.auth.uid;
        }
      }
    }
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /summerClaims/{claimId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                    request.resource.data.keys().hasAll(['userId', 'userName', 'userEmail', 'itemId', 'section', 'timestamp']) &&
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.itemId is string &&
                    request.resource.data.section is string &&
                    request.resource.data.timestamp is timestamp;
      allow update, delete: if isAdmin();
    }

    match /rouletteSpins/{spinId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                    request.resource.data.keys().hasAll(['userId', 'userName', 'userEmail', 'prizeName', 'prizeType', 'prizeValue', 'timestamp']) &&
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.prizeName is string &&
                    request.resource.data.prizeType is string &&
                    request.resource.data.timestamp is timestamp;
      allow update, delete: if isAdmin();
    }

    match /qa_messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                    request.resource.data.keys().hasAll(['text', 'authorId', 'authorName', 'role', 'createdAt']) &&
                    request.resource.data.text is string && request.resource.data.text.size() <= 2000 &&
                    request.resource.data.authorId == request.auth.uid &&
                    request.resource.data.authorName is string &&
                    request.resource.data.role is string &&
                    (!('isVerified' in request.resource.data) || request.resource.data.isVerified is bool) &&
                    (!('replyTo' in request.resource.data) || request.resource.data.replyTo is string) &&
                    (!('replyToUserId' in request.resource.data) || request.resource.data.replyToUserId is string) &&
                    (!('rating' in request.resource.data) || request.resource.data.rating is number) &&
                    request.resource.data.createdAt is timestamp;
      allow update: if isAuthenticated() && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating']) &&
                    request.resource.data.rating is number && 
                    request.resource.data.rating >= 1 && request.resource.data.rating <= 5 &&
                    resource.data.replyToUserId == request.auth.uid;
      allow delete: if isAdmin() || request.auth.uid == resource.data.authorId;
    }

    match /gifts_catalog/{giftId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId}/received_gifts/{giftId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin() || isOwner(userId);
    }

    match /support_chats/{userId} {
      allow read: if isOwner(userId) || canManageThreats();
      allow create: if isOwner(userId) && 
                    request.resource.data.keys().hasAll(['userId', 'userName', 'createdAt', 'updatedAt']) &&
                    request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(userId) || canManageThreats();
      
      match /messages/{messageId} {
        allow read: if isOwner(userId) || canManageThreats();
        allow create: if (isOwner(userId) || canManageThreats()) &&
                      request.resource.data.keys().hasAll(['text', 'authorId', 'createdAt']) &&
                      request.resource.data.authorId == request.auth.uid &&
                      (!('replyTo' in request.resource.data) || request.resource.data.replyTo is string) &&
                      (!('replyToText' in request.resource.data) || request.resource.data.replyToText is string);
        allow update: if isOwner(userId) || canManageThreats();
        allow delete: if canManageThreats() || request.auth.uid == resource.data.authorId;
      }
    }
    match /chats/{chatId}/messages/{messageId} {
      allow read: if isAuthenticated() && chatId.matches('.*' + request.auth.uid + '.*');
      allow create: if isAuthenticated() && 
                    chatId.matches('.*' + request.auth.uid + '.*') &&
                    request.resource.data.senderId == request.auth.uid &&
                    request.resource.data.text is string &&
                    request.resource.data.text.size() > 0 &&
                    request.resource.data.text.size() <= 2000;
      allow update, delete: if false;
    }


    match /calls/{callId} {
      allow read, write: if request.auth != null;
      match /offerCandidates/{candidateId} {
        allow read, write: if request.auth != null;
      }
      match /answerCandidates/{candidateId} {
        allow read, write: if request.auth != null;
      }
    }

    match /target_reports/{reportId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                    request.resource.data.keys().hasAll(['type', 'location', 'authorId', 'authorEmail', 'authorName', 'timestamp', 'imageUrl']) &&
                    request.resource.data.type in ['shahed', 'missile', 'aviation', 'kab', 'recon', 'airplane', 'helicopter', 'drone', 'explosion', 'other'] &&
                    request.resource.data.location.keys().hasAll(['lat', 'lng']) &&
                    request.resource.data.authorId == request.auth.uid &&
                    request.resource.data.imageUrl is string && request.resource.data.imageUrl.size() < 1048576 * 2;
      allow update, delete: if isAdmin();
    }
    match /admin_targets/{targetId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /operation_sky_participants/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }
  }
}

